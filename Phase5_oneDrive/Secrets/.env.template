# Phase5_OneDrive/secrets/.env
# Copy this file to secrets/.env and fill in your values.
# This file must NOT be committed to Git.

# ── Microsoft / Azure ──────────────────────────────────────────
# From your Azure App Registration (portal.azure.com)
AZURE_CLIENT_ID=your-azure-app-client-id-here
AZURE_TENANT_ID=your-azure-tenant-id-here

# The OneDrive folder ID to sync.
# Get it from: Graph Explorer → GET /me/drive/root/children
# or from the folder URL: ...?id=FOLDER_ID_HERE
ONEDRIVE_FOLDER_ID=your-onedrive-folder-id-here

# ── Google Cloud ───────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name

# Vertex AI Search
VERTEX_LOCATION=global
VERTEX_DATASTORE_ID=your-datastore-id

# ── SCALE-TODO ─────────────────────────────────────────────────
