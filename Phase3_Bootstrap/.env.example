# ============================================================================
# Phase 3 Bootstrap — .env template
#
# Copy to `.env` AFTER running `bootstrap.ps1`. The installer writes the real
# `.env` for you to <install-location>/secrets/.env — this file exists only
# so you can see what variables the runtime needs.
# ============================================================================

# ---- Identification ----
COMPANY_NAME="Example Co"
COMPANY_DOMAIN="example.com"

# ---- GCP ----
GCP_PROJECT_ID="your-project-id"
GCP_PROJECT_NUMBER="000000000000"
GCP_REGION="us-central1"
GCP_LOCATION="global"

# ---- Auth ----
GOOGLE_APPLICATION_CREDENTIALS="./secrets/service-account.json"

# ---- GCS buckets ----
GCS_BUCKET_RAW="example-raw"
GCS_BUCKET_PROCESSED="example-processed"
GCS_BUCKET_ARCHIVE=""  # optional

# ---- Vertex AI Search ----
VERTEX_DATA_STORE_ID="example-ds-v1"
VERTEX_ENGINE_ID="example-engine-v1"
VERTEX_TIER="ENTERPRISE"          # or STANDARD
VERTEX_CONTENT_CONFIG="CONTENT_REQUIRED"
VERTEX_INDUSTRY_VERTICAL="GENERIC"
VERTEX_SERVING_CONFIG="projects/${GCP_PROJECT_NUMBER}/locations/${GCP_LOCATION}/collections/default_collection/engines/${VERTEX_ENGINE_ID}/servingConfigs/default_search"

# ---- Connectors: Gmail ----
GMAIL_ENABLED="false"
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET_REF="projects/${GCP_PROJECT_NUMBER}/secrets/gmail-oauth-client-secret/versions/latest"
GMAIL_REFRESH_TOKEN_REF="projects/${GCP_PROJECT_NUMBER}/secrets/gmail-refresh-token/versions/latest"
GMAIL_USER_EMAIL=""
GMAIL_LABEL_FILTER="INBOX"
GMAIL_QUERY=""                    # Gmail search query, e.g. "newer_than:30d has:attachment"
GMAIL_SYNC_SCHEDULE="0 */6 * * *" # every 6 hours

# ---- Connectors: Google Drive ----
GDRIVE_ENABLED="false"
GDRIVE_MODE="service_account"     # or "oauth"
GDRIVE_FOLDER_IDS=""              # comma-separated
GDRIVE_DRIVE_TYPE="my_drive"      # or "shared_drive"
GDRIVE_MIME_ALLOWLIST="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.google-apps.document,image/*"
GDRIVE_SYNC_SCHEDULE="0 */3 * * *"

# ---- Operational ----
LOG_LEVEL="INFO"
DRY_RUN="false"
